{
  "name": "apex-survey-helper",
  "version": "0.0.0",
  "description": "Apex Telemed survey-v2 embed SDK — headless core plus React and Solid adapters.",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "//consume": "Root entry points let the monorepo be consumed directly from source over a `github:` install (no build/registry needed), mirroring @thefortifiedgrp/apex-partner-core. The default export is the Solid adapter; `./core` exposes the headless core. `solid-js` is a peer, supplied by the host app. Consumers that resolve the Solid adapter's internal `@apextelemed/survey-core` import should alias it to `apex-survey-helper/core` until the packages are published to npm.",
  "main": "./packages/solid/src/index.ts",
  "module": "./packages/solid/src/index.ts",
  "types": "./packages/solid/src/index.ts",
  "exports": {
    ".": "./packages/solid/src/index.ts",
    "./solid": "./packages/solid/src/index.ts",
    "./react": "./packages/react/src/index.ts",
    "./core": "./packages/core/src/index.ts"
  },
  "peerDependencies": {
    "solid-js": "^1.9.0"
  },
  "peerDependenciesMeta": {
    "solid-js": {
      "optional": true
    }
  },
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "clean": "rm -rf packages/*/dist",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "npm run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@solidjs/testing-library": "^0.8.10",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "jsdom": "^25.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "solid-js": "^1.9.5",
    "tsup": "^8.3.0",
    "typescript": "^5.8.3",
    "vite-plugin-solid": "^2.11.0",
    "vitest": "^4.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
