{
  "name": "@apextelemed/survey-react",
  "version": "1.0.0",
  "description": "React hook for the Apex Telemed survey-v2 embed flow.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "apex",
    "telemed",
    "survey",
    "react",
    "telehealth"
  ],
  "peerDependencies": {
    "@apextelemed/survey-core": ">=0.0.0",
    "react": ">=18"
  },
  "devDependencies": {
    "@apextelemed/survey-core": "*"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  }
}
